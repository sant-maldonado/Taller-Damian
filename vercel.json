{
  "buildCommand": "cd frontend && npm ci && npx vite build",
  "outputDirectory": "frontend/dist",
  "framework": null,
  "nodeVersion": "20.x",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/frontend/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/frontend/dist/index.html" }
  ]
}
